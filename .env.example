# ===== H4RD G4ME - Variáveis de Ambiente =====
# Copie este arquivo para ".env" e preencha os valores.

# Banco de dados PostgreSQL (ex.: Neon, Supabase, local)
DATABASE_URL="postgresql://usuario:senha@host:5432/banco?sslmode=require"

# --- Integração com a API oficial do Clash of Clans (opcional) ---
# Sem estas variáveis, a Landing e a Sincronização usam dados de fallback.
# Gere o token em https://developer.clashofclans.com (precisa liberar o IP do servidor).
COC_API_TOKEN=""

# Tag do clã (com ou sem #), usada na Landing. Ex.: #2G0ABC
NEXT_PUBLIC_CLAN_TAG=""

# URL pública do site (usada para metadata/OpenGraph). Ex.: https://h4rdgame.com.br
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
